{
  "version": "2.5.32",
  "name": "survey-creator-core",
  "repository": {
    "type": "git",
    "url": "https://github.com/surveyjs/survey-creator.git"
  },
  "scripts": {
    "build": "npm run build:main",
    "build:main": "rollup -c rollup.config.mjs --environment emitMinified,emitNonSourceFiles",
    "build:i18n": "rollup -c rollup.i18n.config.mjs --environment emitMinified",
    "build:all": "npm run build && npm run build:i18n && npm run build:themes",
    "build:themes": "rollup -c rollup.themes.config.mjs --environment emitMinified",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:postcss": "postcss build/survey-creator-core.css --silent -u postcss-calc -u autoprefixer -u postcss-fail-on-warn -u postcss-import -o survey-creator-core.postcss.css && rimraf survey-creator-core.postcss.css",
    "test:core": "vitest run --project core",
    "test:core:watch": "vitest --project core",
    "test:presets": "exit 0",
    "doc_gen": "node doc_generator/editor_docgenerator.js src/entries/index.ts",
    "watch:dev": "rollup -c rollup.config.mjs -w",
    "watch:prod": "rollup -c rollup.config.mjs -w --environment emitMinified",
    "release": "standard-version --message \"Release: %s [azurepipelines skip]\"",
    "remove-package-lock": "rimraf package-lock.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix"
  },
  "dependencies": {
    "survey-core": "../../../survey-library/packages/survey-core/build"
  },
  "devDependencies": {
    "@types/ace": "0.0.32",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/qunit": "2.0.31",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "ace-builds": "1.2.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "fast-glob": "^3.3.3",
    "jest-canvas-mock": "^2.3.1",
    "jsdom": "^25.0.1",
    "papaparse": "^5.5.3",
    "postcss": "8.4.32",
    "postcss-cli": "10.1.0",
    "postcss-fail-on-warn": "0.2.1",
    "postcss-import": "16.1.0",
    "standard-version": "^9.5.0",
    "surveyjs-doc-generator": "git+https://github.com/surveyjs/surveyjs-doc-generator.git",
    "svg-inline-loader": "^0.8.2",
    "ts-loader": "^9.5.2",
    "ts-node": "3.3.0",
    "tslib": "^2.8.1",
    "vitest": "^4.1.5"
  }
}
