{
  "name": "survey-creator-react",
  "version": "2.5.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/surveyjs/survey-creator.git"
  },
  "scripts": {
    "start": "http-server . -o -c-1",
    "serve": "http-server --silent",
    "test": "jest",
    "test:update": "npm run test -- -u",
    "test:generate-output": "jest --json --outputFile=.jest-test-results.json || echo",
    "test:dev": "jest --watch",
    "test_debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand",
    "doc:gen": "node doc_generator/editor_docgenerator.js src/entries/index.ts",
    "doc:update": "chmod +x docupdate_npm.sh && ./docupdate_npm.sh",
    "testcafe": "testcafe ../../functionalTests/ --app \"http-server\" --selector-timeout 1500 --config-file .testcaferc.dev.js",
    "testcafe:ci": "testcafe ../../functionalTests/ --app \"http-server --silent \" --selector-timeout 1500 --reporter minimal",
    "testcafe:file": "testcafe ../../functionalTests/designer/page-navigator.ts --app \"http-server --silent \" --reporter minimal --debug-mode --config-file .testcaferc.dev.js",
    "release": "standard-version --message \"Release: %s [azurepipelines skip]\"",
    "remove-package-lock": "rimraf package-lock.json",
    "build:main": "rollup -c rollup.config.mjs --environment emitMinified,emitNonSourceFiles",
    "build:presets": "rollup -c rollup.presets.config.mjs --environment emitMinified",
    "build": "npm run build:main && npm run build:presets",
    "watch:dev": "rollup -c rollup.config.mjs -w",
    "watch:prod": "rollup -c rollup.config.mjs -w --environment emitMinified",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test:a11y": "playwright test --project a11y --ui",
    "test:a11y:ci": "playwright test --project a11y --reporter dot --quiet",
    "e2e": "playwright test --project e2e --ui",
    "e2e:ci": "playwright test --project e2e",
    "test:scr": "playwright test --project scr --ui",
    "test:scr:ci": "playwright test --project scr",
    "test:scr:copy:tests": "node copy-src-tests.js",
    "test:scr:legacy": "node copy-src-tests.js && playwright test --project scr_legacy --ui",
    "test:scr:legacy:ci": "node copy-src-tests.js && playwright test --project scr_legacy"
  },
  "devDependencies": {
    "@types/ace": "0.0.44",
    "@types/jest": "^26.0.24",
    "@types/jquery": "3.3.29",
    "@types/node": "7.0.4",
    "@types/react": "^17.0.83",
    "@types/react-dom": "^17.0.1",
    "@types/react-test-renderer": "^17.0.1",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.3.1",
    "jest-environment-jsdom": "^29.7.0",
    "react-test-renderer": "^17.0.1",
    "rimraf": "2.5.4",
    "rollup": "^4.59.0",
    "sass": "^1.62.1",
    "sass-loader": "^8.0.2",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "survey-core": "../../../survey-library/packages/survey-core/build",
    "survey-creator-core": "../survey-creator-core/build",
    "survey-react-ui": "../../../survey-library/packages/survey-react-ui/build"
  }
}
